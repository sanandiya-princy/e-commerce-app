  <!-- Toasts Placement -->
  <div class="toast-container" id="toast-container"></div>

  <!-- ==========================================
       SERVER STATE JSON
       ========================================== -->
  <script id="server-state" type="application/json">
    <%- JSON.stringify({ products, cart }).replace(/</g, '\u003c') %>
  </script>

  <!-- ==========================================
       CLIENT SIDE STATE ENGINE & CONTROLLER
       ========================================== -->
  <script>
    // Server Injected State Variables
    const serverState = JSON.parse(document.getElementById('server-state').textContent);
    let products = serverState.products;
    let cart = serverState.cart;
    
    // UI Local State Variables
    let currentView = 'shop'; // 'shop' or 'admin'
    let activeCategory = 'All';
    let searchQuery = '';
    let activeSort = 'featured';
    let currentOpenProductId = null;

    // Elements
    const shopViewPanel = document.getElementById('shop-view-panel');
    const adminViewPanel = document.getElementById('admin-view-panel');
    const viewSwitchText = document.getElementById('view-switch-text');
    const searchBarWrapper = document.getElementById('search-bar-wrapper');
    const productGrid = document.getElementById('product-grid');
    const adminTableBody = document.getElementById('admin-table-body');
    const categoryTabsContainer = document.getElementById('category-tabs-container');
    const cartCountBadge = document.getElementById('cart-count-badge');
    const cartItemsContainer = document.getElementById('cart-items-container');
    const cartFooterContainer = document.getElementById('cart-footer-container');
    const cartDrawer = document.getElementById('cart-drawer');
    const cartBackdrop = document.getElementById('cart-backdrop');
    const toastContainer = document.getElementById('toast-container');

    // 1. Initial Launch
    window.addEventListener('DOMContentLoaded', () => {
      renderCategories();
      renderStorefront();
      renderAdminTable();
      updateCartUI();
    });

    // 2. Light / Dark Theme Toggling
    const themeToggle = document.getElementById('theme-toggle');
    const sunIcon = themeToggle.querySelector('.sun-icon');
    const moonIcon = themeToggle.querySelector('.moon-icon');

    if (localStorage.getItem('theme') === 'dark' || (!localStorage.getItem('theme') && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
      document.body.classList.add('dark-mode');
      sunIcon.style.display = 'block';
      moonIcon.style.display = 'none';
    } else {
      document.body.classList.remove('dark-mode');
      sunIcon.style.display = 'none';
      moonIcon.style.display = 'block';
    }

    themeToggle.addEventListener('click', () => {
      document.body.classList.toggle('dark-mode');
      const isDark = document.body.classList.contains('dark-mode');
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
      sunIcon.style.display = isDark ? 'block' : 'none';
      moonIcon.style.display = isDark ? 'none' : 'block';
    });

    // 3. SPA View Switcher
    function toggleView() {
      switchView(currentView === 'shop' ? 'admin' : 'shop');
    }

    function switchView(view) {
      currentView = view;
      if (currentView === 'shop') {
        shopViewPanel.classList.remove('hidden');
        adminViewPanel.classList.add('hidden');
        searchBarWrapper.classList.remove('hidden');
