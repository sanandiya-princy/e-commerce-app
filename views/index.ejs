    // 4. Client-Side Rendering of Product Grid (Storefront)
    function renderStorefront() {
      const filtered = getFilteredAndSorted();
      
      if (filtered.length === 0) {
        productGrid.innerHTML = `
          <div style="grid-column: 1/-1; text-align: center; padding: 4rem 1rem; color: var(--text-secondary);">
            <svg style="width: 48px; height: 48px; margin-bottom: 1rem;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <h3>No Products Found</h3>
            <p style="margin-top: 0.5rem;">Try modifying your search query or filters.</p>
          </div>
        `;
        return;
      }

      productGrid.innerHTML = filtered.map(prod => `
        <article class="card" id="card-${prod.id}">
          <span class="badge-category">${prod.category}</span>
          ${prod.stock > 0 
            ? `<span class="badge-stock stock-in">In Stock (${prod.stock})</span>` 
            : `<span class="badge-stock stock-out">Out of Stock</span>`
          }

          <div class="card-img-wrapper" style="cursor: pointer;" onclick="openProductModal('${prod.id}')">
            <img src="${prod.image}" alt="${prod.name}" loading="lazy" onerror="this.src='https://images.unsplash.com/photo-1523275335684-37898b6baf30?w=500&auto=format&fit=crop&q=60&ixlib=rb-4.0.3'">
          </div>

          <div class="card-content">
            <div class="card-rating">
              <svg viewBox="0 0 24 24">
                <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>
              </svg>
              ${prod.rating.toFixed(1)} <span>(${prod.reviews.length} reviews)</span>
            </div>
            <h3 class="card-title" style="cursor: pointer;" onclick="openProductModal('${prod.id}')">${prod.name}</h3>
            <p class="card-description">${prod.description}</p>

            <div class="card-footer">
              <div class="price">${prod.price.toFixed(2)}</div>
              <div style="display:flex; gap: 0.5rem;">
                <button onclick="openProductModal('${prod.id}')" class="btn-icon" aria-label="Quick View">
                  <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                  </svg>
                </button>
                <button onclick="handleAddToCart('${prod.id}')" class="btn-text btn-primary" ${prod.stock <= 0 ? 'disabled' : ''} style="padding: 0.6rem 1rem;">
                  Add
                </button>
              </div>
            </div>
          </div>
        </article>
      `).join('');
    }

    // 5. Client-Side Rendering of Admin Dashboard
    function renderAdminTable() {
      adminTableBody.innerHTML = products.map(prod => `
        <tr id="admin-tr-${prod.id}">
          <td>
            <div class="admin-item-meta">
              <img class="admin-item-img" src="${prod.image}" alt="${prod.name}" onerror="this.src='https://images.unsplash.com/photo-1523275335684-37898b6baf30?w=500&auto=format&fit=crop&q=60&ixlib=rb-4.0.3'">
              <div>
                <span class="admin-item-title">${prod.name}</span>
                <p style="font-size: 0.75rem; color: var(--text-secondary); max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">${prod.description}</p>
              </div>
            </div>
          </td>
          <td><span class="badge-category" style="position:static;">${prod.category}</span></td>
          <td><span style="font-weight:700;">$${prod.price.toFixed(2)}</span></td>
          <td>
            ${prod.stock > 0 
              ? `<span style="color:var(--accent); font-weight:700;">${prod.stock} units</span>` 
              : `<span style="color:var(--danger); font-weight:700;">Out of Stock</span>`
            }
          </td>
          <td style="font-weight:600;"><span style="color: var(--warning)">★</span> ${prod.rating.toFixed(1)}</td>
          <td>
            <div class="admin-actions" style="justify-content: flex-end;">
              <button class="btn-icon" onclick="openEditProductModal('${prod.id}')" aria-label="Edit Product">
                <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                </svg>
              </button>
              <button class="btn-icon" style="color:var(--danger); border-color:var(--border);" onclick="handleDeleteProduct('${prod.id}')" aria-label="Delete Product">
                <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                </svg>
              </button>
            </div>
          </td>
        </tr>
      `).join('');
    }

    // 6. Render Categories filters
    function renderCategories() {
      const categories = ["All", ...new Set(products.map(p => p.category))];
      categoryTabsContainer.innerHTML = categories.map(cat => `
        <button onclick="handleCategoryFilter('${cat}')" class="tab ${activeCategory === cat ? 'active' : ''}">
          ${cat}
        </button>
      `).join('');
    }

    // 7. Instant Search, Sorting and Filtering logic
    function getFilteredAndSorted() {
      let filtered = [...products];

      if (activeCategory !== 'All') {
        filtered = filtered.filter(p => p.category.toLowerCase() === activeCategory.toLowerCase());
      }

      if (searchQuery) {
        const query = searchQuery.toLowerCase().trim();
        filtered = filtered.filter(p => 
          p.name.toLowerCase().includes(query) || 
          p.description.toLowerCase().includes(query)
        );
      }

      if (activeSort === 'price-asc') {
        filtered.sort((a, b) => a.price - b.price);
      } else if (activeSort === 'price-desc') {
        filtered.sort((a, b) => b.price - a.price);
      } else if (activeSort === 'rating') {
        filtered.sort((a, b) => b.rating - a.rating);
      }

      return filtered;
    }

    function handleCategoryFilter(category) {
      activeCategory = category;
      renderCategories();
      renderStorefront();
    }

    function handleSearch(val) {
      searchQuery = val;
      renderStorefront();
    }

    function handleSort(val) {
      activeSort = val;
      renderStorefront();
    }

    // 8. Open Modals
    function openModal(id) {
      document.getElementById(id).classList.add('active');
    }

    function closeModal(id) {
      document.getElementById(id).classList.remove('active');
    }

    // 9. Product Details and Review Modal
    function openProductModal(productId) {
      const product = products.find(p => p.id === productId);
      if (!product) return;
      
      currentOpenProductId = productId;

      document.getElementById('detail-title').textContent = product.name;
      document.getElementById('detail-image').src = product.image;
      document.getElementById('detail-image').alt = product.name;
      document.getElementById('detail-badge').textContent = product.category;
      document.getElementById('detail-desc').textContent = product.description;
      document.getElementById('detail-price').textContent = product.price.toFixed(2);
      
      document.getElementById('detail-add-id').value = product.id;
      document.getElementById('review-product-id').value = product.id;

      // Stock levels
      const stockElement = document.getElementById('detail-stock');
      const addBtn = document.getElementById('detail-add-btn');
      if (product.stock > 0) {
        stockElement.innerHTML = `<span style="color:var(--accent)">In Stock (${product.stock} available)</span>`;
        addBtn.disabled = false;
        addBtn.textContent = "Add to Shopping Cart";
      } else {
        stockElement.innerHTML = `<span style="color:var(--danger)">Out of Stock</span>`;
        addBtn.disabled = true;
        addBtn.textContent = "Out of Stock";
      }

      // Ratings
      document.getElementById('detail-rating').innerHTML = `
        <svg viewBox="0 0 24 24"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
        ${product.rating.toFixed(1)} <span>(${product.reviews.length} reviews)</span>
      `;

      // Reviews rendering
      renderReviewsList(product.reviews);

      // Reset form
      document.querySelectorAll('.star-rating input').forEach(inp => inp.checked = false);
      document.getElementById('review-author').value = '';
      document.getElementById('review-comment').value = '';

      openModal('detail-backdrop');
    }

    function renderReviewsList(reviews) {
      const reviewsList = document.getElementById('detail-reviews-list');
      reviewsList.innerHTML = '';
      if (reviews.length === 0) {
        reviewsList.innerHTML = `<p style="font-size:0.85rem; color:var(--text-secondary); font-style:italic;">No reviews yet. Be the first to leave one!</p>`;
      } else {
        reviewsList.innerHTML = reviews.map(rev => `
          <div class="review-item">
            <div class="review-header">
              <span class="review-author">${escapeHTML(rev.author)}</span>
              <span class="review-rating">${'★'.repeat(rev.rating)}</span>
            </div>
            <p class="review-comment">${escapeHTML(rev.comment)}</p>
          </div>
        `).join('');
      }
    }

    function escapeHTML(str) {
      return str.replace(/[&<>'"]/g, 
        tag => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', "'": '&#39;', '"': '&quot;' }[tag] || tag)
      );
    }

    // 10. AJAX Cart Operations (Instant Dynamic Updates)
    const cartBtn = document.getElementById('cart-btn');
    cartBtn.addEventListener('click', toggleCart);

    function toggleCart() {
      cartDrawer.classList.toggle('active');
      cartBackdrop.classList.toggle('active');
    }

    function updateCartUI() {
      // Badge count
      if (cart.totalItems > 0) {
        cartCountBadge.classList.remove('hidden');
        cartCountBadge.textContent = cart.totalItems;
      } else {
        cartCountBadge.classList.add('hidden');
      }

      // Drawer Content
      if (cart.items.length === 0) {
        cartItemsContainer.innerHTML = `
          <div class="cart-empty">
            <svg width="48" height="48" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
            </svg>
            <p>Your cart is empty.</p>
            <button class="btn-text btn-primary" onclick="toggleCart()" style="margin-top: 1rem; font-size: 0.8rem;">Browse Products</button>
          </div>
        `;
        cartFooterContainer.innerHTML = '';
      } else {
        cartItemsContainer.innerHTML = cart.items.map(item => `
          <div class="cart-item">
            <img class="cart-item-img" src="${item.image}" alt="${item.name}" onerror="this.src='https://images.unsplash.com/photo-1523275335684-37898b6baf30?w=500&auto=format&fit=crop&q=60&ixlib=rb-4.0.3'">
            <div class="cart-item-info">
              <div class="cart-item-title">${item.name}</div>
              <div class="cart-item-price">$${(item.price * item.quantity).toFixed(2)} <span style="font-weight:400; font-size: 0.75rem; color:var(--text-secondary)">($${item.price} each)</span></div>
              
              <div class="cart-item-controls">
                <div class="qty-selectors">
                  <button onclick="handleUpdateQty('${item.productId}', ${item.quantity - 1})" class="qty-btn" aria-label="Decrease quantity">-</button>
                  <span class="qty-val">${item.quantity}</span>
                  <button onclick="handleUpdateQty('${item.productId}', ${item.quantity + 1})" class="qty-btn" aria-label="Increase quantity">+</button>
                </div>

                <button onclick="handleRemoveFromCart('${item.productId}')" style="background:none; border:none; cursor:pointer; color:var(--danger); display:flex; align-items:center;" aria-label="Remove item">
                  <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                  </svg>
                </button>
              </div>
            </div>
          </div>
        `).join('');

        cartFooterContainer.innerHTML = `
          <div class="cart-footer">
            <div class="summary-row">
              <span>Subtotal</span>
              <span style="font-weight:700; color:var(--text-primary);">$${cart.total.toFixed(2)}</span>
            </div>
            <div class="summary-row">
              <span>Shipping</span>
              <span style="color:var(--accent); font-weight:700;">FREE</span>
            </div>
            <div class="summary-row total">
              <span>Total</span>
              <span>$${cart.total.toFixed(2)}</span>
            </div>
            <button class="btn-text btn-primary" onclick="openCheckoutModal()" style="width: 100%; justify-content: center; padding: 0.9rem;">
              Proceed to Checkout
            </button>
          </div>
        `;
      }
    }

    // Call POST add
    async function handleAddToCart(productId) {
      try {
        const response = await fetch('/cart/add', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ productId, quantity: 1 })
        });
        const result = await response.json();
        
        if (result.success) {
          cart = result.cart;
          updateCartUI();
          showToast('Added item to cart!');
          // Anim drawer open for clean feedback
          if (!cartDrawer.classList.contains('active')) {
            toggleCart();
          }
        }
      } catch (err) {
        console.error('Add cart error:', err);
      }
    }

    // Handle Quick View Detail modal form submit
    async function handleDetailAddForm(e) {
      e.preventDefault();
      const productId = document.getElementById('detail-add-id').value;
      closeModal('detail-backdrop');
      await handleAddToCart(productId);
    }

    // Change qty
    async function handleUpdateQty(productId, quantity) {
      try {
        const response = await fetch('/cart/update', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ productId, quantity })
        });
        const result = await response.json();
        
        if (result.success) {
          cart = result.cart;
          updateCartUI();
        }
      } catch (err) {
        console.error('Update cart error:', err);
      }
    }

    // Remove
    async function handleRemoveFromCart(productId) {
      try {
        const response = await fetch('/cart/remove', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ productId })
        });
        const result = await response.json();
        
        if (result.success) {
          cart = result.cart;
          updateCartUI();
          showToast('Removed item from cart.');
        }
      } catch (err) {
        console.error('Remove cart error:', err);
      }
    }

    // 11. Checkout Form AJAX Submission (Fewer file, rapid feel)
    function openCheckoutModal() {
      toggleCart();
      document.getElementById('checkout-pay-btn').textContent = `Pay $${cart.total.toFixed(2)} Now`;
      openModal('checkout-backdrop');
    }

    async function handleCheckoutSubmit(e) {
      e.preventDefault();
      
      const processingOverlay = document.getElementById('payment-processing');
      processingOverlay.classList.add('active');

      const name = document.getElementById('shipping-name').value;
      const email = document.getElementById('shipping-email').value;
      const address = document.getElementById('shipping-address').value;

      // Simulated tiny delay (300ms) for high-performance responsive look
      setTimeout(async () => {
        try {
          const response = await fetch('/checkout', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ name, email, address })
          });
          const result = await response.json();

          processingOverlay.classList.remove('active');
          closeModal('checkout-backdrop');

          if (result.success) {
            // Update local state and redraw storefront grids (stocks decreased)
            products = result.products;
            renderStorefront();
            renderAdminTable();
            
            // Clear local cart
            cart = { items: [], total: 0, totalItems: 0 };
            updateCartUI();

            // Open success overlay
            document.getElementById('success-buyer-name').textContent = result.buyerName;
            document.getElementById('success-order-id').textContent = result.orderId;
            openModal('success-overlay');
          }
        } catch (err) {
          processingOverlay.classList.remove('active');
          console.error('Checkout error:', err);
        }
      }, 400);
    }

    function closeSuccessOverlay() {
      document.getElementById('success-overlay').classList.remove('active');
    }

    // 12. Review submission AJAX
    async function handleReviewForm(e) {
      e.preventDefault();
      
      const productId = document.getElementById('review-product-id').value;
      const author = document.getElementById('review-author').value;
      const comment = document.getElementById('review-comment').value;
      
      // Get selected star rating
      let rating = 5;
      const checkedRating = document.querySelector('input[name="rating"]:checked');
      if (checkedRating) rating = checkedRating.value;

      try {
        const response = await fetch('/product/review', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ productId, author, rating, comment })
        });
        const result = await response.json();

        if (result.success) {
          // Update local product details
          products = result.products;
          
          // Re-render
          renderStorefront();
          renderAdminTable();
          
          // Update review list in open modal
          const updatedProduct = products.find(p => p.id === productId);
          if (updatedProduct) {
            renderReviewsList(updatedProduct.reviews);
            document.getElementById('detail-rating').innerHTML = `
              <svg viewBox="0 0 24 24"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
              ${updatedProduct.rating.toFixed(1)} <span>(${updatedProduct.reviews.length} reviews)</span>
            `;
          }

          // Reset inputs
          document.getElementById('review-author').value = '';
          document.getElementById('review-comment').value = '';
          document.querySelectorAll('.star-rating input').forEach(inp => inp.checked = false);
          
          showToast('Review submitted!');
        }
      } catch (err) {
        console.error('Review submit error:', err);
      }
    }

    // 13. Admin Management Modals & Operations
    function openAddProductModal() {
      document.getElementById('admin-modal-title').textContent = "Add New Product";
      document.getElementById('admin-form-id').value = "";
      document.getElementById('admin-form-name').value = "";
      document.getElementById('admin-form-category').value = "";
      document.getElementById('admin-form-image').value = "";
      document.getElementById('admin-form-price').value = "";
      document.getElementById('admin-form-stock').value = "";
      document.getElementById('admin-form-desc').value = "";

      openModal('admin-product-backdrop');
    }

    function openEditProductModal(productId) {
      const product = products.find(p => p.id === productId);
      if (!product) return;

      document.getElementById('admin-modal-title').textContent = "Edit Product Details";
      document.getElementById('admin-form-id').value = product.id;
      document.getElementById('admin-form-name').value = product.name;
      document.getElementById('admin-form-category').value = product.category;
      document.getElementById('admin-form-image').value = product.image;
      document.getElementById('admin-form-price').value = product.price;
      document.getElementById('admin-form-stock').value = product.stock;
      document.getElementById('admin-form-desc').value = product.description;

      openModal('admin-product-backdrop');
    }

    async function handleAdminFormSubmit(e) {
      e.preventDefault();
      
      const id = document.getElementById('admin-form-id').value;
      const name = document.getElementById('admin-form-name').value;
      const category = document.getElementById('admin-form-category').value;
      const image = document.getElementById('admin-form-image').value;
      const price = parseFloat(document.getElementById('admin-form-price').value) || 0;
      const stock = parseInt(document.getElementById('admin-form-stock').value) || 0;
      const description = document.getElementById('admin-form-desc').value;

      const url = id ? '/product/edit' : '/product/add';
      const body = { id, name, category, image, price, stock, description };

      try {
        const response = await fetch(url, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body)
        });
        const result = await response.json();

        if (result.success) {
          products = result.products;
          renderCategories();
          renderStorefront();
          renderAdminTable();
          closeModal('admin-product-backdrop');
          showToast(id ? 'Product updated!' : 'Product added successfully!');
        }
      } catch (err) {
        console.error('Admin submit error:', err);
      }
    }

    async function handleDeleteProduct(id) {
      if (!confirm('Are you sure you want to delete this product?')) return;

      try {
        const response = await fetch('/product/delete', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id })
        });
        const result = await response.json();

        if (result.success) {
          products = result.products;
          renderCategories();
          renderStorefront();
          renderAdminTable();
          showToast('Product deleted.');
        }
      } catch (err) {
        console.error('Delete product error:', err);
      }
    }

    // 14. Toasts Display Helper
    function showToast(message) {
      const toast = document.createElement('div');
      toast.className = 'toast';
      toast.innerHTML = `
        <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color:var(--primary);">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        <span>${message}</span>
      `;
      toastContainer.appendChild(toast);

      // Auto dismiss
      setTimeout(() => {
        toast.style.animation = 'none'; // reset anim
        toast.offsetHeight; // trigger reflow
        toast.style.transform = 'translateY(100px)';
        toast.style.opacity = '0';
        toast.style.transition = 'all 0.2s ease';
        setTimeout(() => toast.remove(), 200);
      }, 2500);
    }
  </script>
</body>
</html>
